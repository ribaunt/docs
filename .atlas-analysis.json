{
  "projectType": "sdk-library",
  "projectName": "Ribaunt",
  "projectDescription": "A stateless proof-of-work CAPTCHA library for Node.js and modern browsers that issues signed JWT challenges from your server, solves them in the browser, and verifies submitted proofs without storing state.",
  "theme": "luma",
