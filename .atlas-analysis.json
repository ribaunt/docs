  "keyFeatures": [
    "Stateless challenge tokens signed with RIBAUNT_SECRET — no database required",
    "Proof-of-work solver runs entirely in the browser using the Web Crypto API",
    "Built-in `<ribaunt-widget>` Web Component for plain HTML apps",
    "React and Next.js wrapper via `ribaunt/widget-react` with typed callback props",
    "Process-local replay protection by default; pluggable remote store (Redis/Valkey) for serverless deployments",
    "Configurable difficulty, challenge count, and TTL",
    "CSS custom properties for full widget theming and dark mode support",
    "TypeScript types included across all entry points"
  ],
  "publicApiSurface": [
    "createChallenge(difficulty, amount, ttlSeconds): ChallengeToken[]",
    "verifySolution(tokens, solutions, options?): Promise<boolean>",
    "solveChallenge(token, options?): ChallengeSolution | ChallengeSolution[] | undefined",
    "RibauntWidget (Web Component: <ribaunt-widget>)",
    "RibauntWidget (React: ribaunt/widget-react default export)",
    "ReplayStore interface: { consume(jti, expiresAt): Promise<boolean> }",
    "VerifySolutionOptions: { replayPrevention, replayStore, debug, onWarning }",
    "SolveChallengeOptions: { maxIterations, maxDurationMs }",
    "Widget events: verify, error, state-change",
    "Widget attributes: challenge-endpoint, verify-endpoint, auto-verify, show-warning, warning-message, solve-timeout, disabled"
  ]
}
